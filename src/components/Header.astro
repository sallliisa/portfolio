---
import CommitStrip from './CommitStrip.astro';

const pathname = Astro.url.pathname;
const isProjectsActive = pathname === '/' || pathname === '/index.html' || pathname === '';
const isClientWorkActive = pathname.startsWith('/client-work');
---

<header id="site-header">
  <div class="header-blur-extension" aria-hidden="true"></div>
  <CommitStrip />
  <div class="header-left">
    <a href="/" id="site-name">southneuhof</a>
    <nav class="header-nav">
      <a href="/" class={`nav-link ${isProjectsActive ? 'active' : ''}`}>projects</a>
      <a href="/client-work" class={`nav-link ${isClientWorkActive ? 'active' : ''}`}>client work</a>
    </nav>
  </div>
  <div class="header-right">
    <a href="https://github.com/sallliisa" target="_blank" rel="noopener noreferrer" class="github-link" aria-label="GitHub Profile">
      <svg viewBox="0 0 16 16" width="16" height="16" fill="currentColor" aria-hidden="true">
        <path d="M8 0c4.42 0 8 3.58 8 8a8.013 8.013 0 0 1-5.45 7.59c-.4.08-.55-.17-.55-.38 0-.27.01-1.13.01-2.2 0-.75-.25-1.23-.54-1.48 1.78-.2 3.65-.88 3.65-3.95 0-.88-.31-1.59-.82-2.15.08-.2.36-1.02-.08-2.12 0 0-.67-.22-2.2.82-.64-.18-1.32-.27-2-.27-.68 0-1.36.09-2 .27-1.53-1.03-2.2-.82-2.2-.82-.44 1.1-.16 1.92-.08 2.12-.51.56-.82 1.28-.82 2.15 0 3.06 1.86 3.75 3.64 3.95-.23.2-.44.55-.51 1.07-.46.21-1.61.55-2.33-.66-.15-.24-.6-.83-1.23-.82-.67.01-.27.38.01.53.34.19.73.9.82 1.13.16.45.68 1.35 3.1 1.07.01.67.01 1.32.01 1.57 0 .21-.15.46-.55.38A8.012 8.012 0 0 1 0 8c0-4.42 3.58-8 8-8z"/>
      </svg>
    </a>
  </div>
</header>
