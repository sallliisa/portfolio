---
import ProjectSection from '../ProjectSection.astro';
---

<ProjectSection
  id="project-is-framework"
  title="is-framework"
  images={[
    "/images/is-framework-code.png",
    "/images/is-framework-dashboard.png",
    "/images/is-framework-mobile.png"
  ]}
>
  <p>
    Canonical monorepo framework for South Neuhof information system
    frontends. Standardized on pnpm workspaces, Vite, and Turbo, it
    provides the core infrastructure for scalable Vue 3 and Expo
    mobile client applications.
  </p>
  <p>
    Publishes shared model schemas, API contracts, and components
    under the @southneuhof scope. Enables source-first development
    with Vite HMR mappings and strict package boundary checks.
  </p>
</ProjectSection>
