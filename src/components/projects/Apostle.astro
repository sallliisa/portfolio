---
import ProjectSection from "../ProjectSection.astro";
---

<ProjectSection
  id="project-apostle"
  title="apostle"
  images={[
    // "/images/apostle-network.png",
    // "/images/apostle-request.png",
    // "/images/apostle-terminal.png"
  ]}
>
  <p>
    A type-safe HTTP client wrapper and request lifecycle orchestration package.
    It is the shared network layer for South Neuhof frontends, published under
    the @southneuhof scope.
  </p>
  <p>
    Handles retry logic, global authorization headers, and response payload
    validation helpers while keeping overhead low on mobile and browser targets.
  </p>
  <p class="project-link-wrapper">
    <a
      href="https://github.com/southneuhof/apostle"
      target="_blank"
      rel="noopener noreferrer"
      class="project-external-link"
    >
      View repository on GitHub →
    </a>
  </p>
</ProjectSection>

<style>
  .project-link-wrapper {
    margin-top: 8px;
  }
  .project-external-link {
    font-family: var(--font-body);
    font-size: 12px;
    color: var(--fg);
    text-decoration: none;
    border-bottom: 1px solid var(--fg-20);
    padding-bottom: 2px;
    transition: all 0.2s ease;
    display: inline-block;
  }
  .project-external-link:hover {
    border-bottom-color: var(--fg);
    opacity: 0.8;
  }
</style>
