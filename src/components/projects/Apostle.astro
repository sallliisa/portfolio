---
import ProjectSection from '../ProjectSection.astro';
---

<ProjectSection
  id="project-apostle"
  title="apostle"
  images={[
    "/images/apostle-network.png",
    "/images/apostle-request.png",
    "/images/apostle-terminal.png"
  ]}
>
  <p>
    A type-safe HTTP client wrapper and request lifecycle
    orchestration package. It serves as the unified network
    communication layer for South Neuhof frontends, published under
    the @southneuhof scope.
  </p>
  <p>
    Provides automated retry algorithms, global authorization header
    injection, and response payload validation helper utilities.
    Engineered to maintain low overhead on mobile and browser targets.
  </p>
</ProjectSection>
