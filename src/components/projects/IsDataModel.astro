---
import ProjectSection from "../ProjectSection.astro";
---

<ProjectSection
  id="project-is-data-model"
  title="is-data-model"
  images={[
    // "/images/velox-1.png",
    // "/images/velox-2.png",
    // "/images/velox-3.png",
  ]}
>
  <p>
    Shared data validation schemas and enterprise API contract definitions.
    Keeps server responses aligned with clientside TypeScript interfaces.
  </p>
  <p>
    Acts as the single source of truth for database models, protocol
    definitions, and DTO verification rules across microservices and client
    applications.
  </p>
  <p class="project-link-wrapper">
    <a
      href="https://github.com/southneuhof/is-data-model"
      target="_blank"
      rel="noopener noreferrer"
      class="project-external-link"
    >
      View repository on GitHub →
    </a>
  </p>
</ProjectSection>

<style>
  .project-link-wrapper {
    margin-top: 8px;
  }
  .project-external-link {
    font-family: var(--mono);
    font-size: 12px;
    color: var(--fg);
    text-decoration: none;
    border-bottom: 1px solid var(--fg-20);
    padding-bottom: 2px;
    transition: all 0.2s ease;
    display: inline-block;
  }
  .project-external-link:hover {
    border-bottom-color: var(--fg);
    opacity: 0.8;
  }
</style>
