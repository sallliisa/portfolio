---
import ProjectSection from "../ProjectSection.astro";
---

<ProjectSection
  id="project-is-vue-framework"
  title="is-vue-framework"
  images={[
    // "/images/aurora-1.png",
    // "/images/aurora-2.png",
    // "/images/aurora-3.png",
  ]}
>
  <p>
    Vue 3 component library and composition primitives for South Neuhof
    frontends. Built on Vite and TypeScript to keep UI behavior consistent and
    client builds fast.
  </p>
  <p>
    Includes design system tokens, responsive grid layouts, and custom hooks
    designed to run with zero layout shift on web targets.
  </p>
  <p class="project-link-wrapper">
    <a
      href="https://github.com/southneuhof/is-vue-framework"
      target="_blank"
      rel="noopener noreferrer"
      class="project-external-link"
    >
      View repository on GitHub →
    </a>
  </p>
</ProjectSection>

<style>
  .project-link-wrapper {
    margin-top: 8px;
  }
  .project-external-link {
    font-family: var(--font-body);
    font-size: 12px;
    color: var(--fg);
    text-decoration: none;
    border-bottom: 1px solid var(--fg-20);
    padding-bottom: 2px;
    transition: all 0.2s ease;
    display: inline-block;
  }
  .project-external-link:hover {
    border-bottom-color: var(--fg);
    opacity: 0.8;
  }
</style>
