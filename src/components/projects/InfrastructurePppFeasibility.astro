---
import ProjectSection from '../ProjectSection.astro';
---

<ProjectSection
  id="project-infrastructure-ppp-feasibility"
  title="PPP Feasibility Suite"
  images={[
    "/images/is-framework-dashboard.png",
    "/images/helios-1.png",
    "/images/velox-1.png"
  ]}
>
  <p>
    An end-to-end enterprise planning and project monitoring suite developed for a
    state-owned infrastructure conglomerate to govern Public-Private Partnership (PPP) developments.
  </p>
  <p>
    Combines a dynamic feasibility simulator (estimating investment costs, operating revenues,
    loan amortizations, and financial statements) with an interactive management dashboard. Features
    automated "Go / No Go" assessments for multi-sector assets (roads, bridges, dams, ports, water systems)
    along with public landing portals and GIS-mapped project milestone tracking.
  </p>
</ProjectSection>
