---
import ProjectSection from "../ProjectSection.astro";
---

<ProjectSection
  id="project-utilities"
  title="utilities"
  images={[
    // "/images/is-framework-code.png",
    // "",
    // "",
  ]}
>
  <p>
    Core helper methods, monorepo package boundary checks, and compilation
    scripts. Standardizes linting, formatting, and build pipelines.
  </p>
  <p>
    Manages shared algorithms, date-time calculation libraries, and execution
    pipeline config files used across both development and build phases.
  </p>
  <p class="project-link-wrapper">
    <a
      href="https://github.com/southneuhof/utilities"
      target="_blank"
      rel="noopener noreferrer"
      class="project-external-link"
    >
      View repository on GitHub →
    </a>
  </p>
</ProjectSection>

<style>
  .project-link-wrapper {
    margin-top: 8px;
  }
  .project-external-link {
    font-family: var(--mono);
    font-size: 12px;
    color: var(--fg);
    text-decoration: none;
    border-bottom: 1px solid var(--fg-20);
    padding-bottom: 2px;
    transition: all 0.2s ease;
    display: inline-block;
  }
  .project-external-link:hover {
    border-bottom-color: var(--fg);
    opacity: 0.8;
  }
</style>
