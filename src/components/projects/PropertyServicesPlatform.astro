---
import ProjectSection from "../ProjectSection.astro";
---

<ProjectSection
  id="project-property-services-platform"
  title="On-Demand Property Services Platform"
  images={[
    "/images/tulen.png",
    "/images/tulen-logo.svg",
    // "/images/airwave-spatial.png"
  ]}
>
  <p>
    Two-sided on-demand marketplace connecting commercial and residential
    property owners with certified technicians for routine maintenance and
    climate-control (HVAC) inspections.
  </p>
  <p>
    Built under a state-owned infrastructure conglomerate to keep service
    quality consistent across independent providers. The platform pairs a
    high-concurrency consumer booking app with a partner workflow tool for
    technician dispatch, logistics, and payout management.
  </p>
</ProjectSection>
