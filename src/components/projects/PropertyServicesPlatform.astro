---
import ProjectSection from '../ProjectSection.astro';
---

<ProjectSection
  id="project-property-services-platform"
  title="On-Demand Property Services Platform"
  images={[
    "/images/is-framework-mobile.png",
    "/images/landing-sveltekit-framework-components.png",
    "/images/airwave-spatial.png"
  ]}
>
  <p>
    Two-sided on-demand marketplace connecting commercial and residential property
    owners with certified technicians for routine maintenance and climate-control (HVAC)
    inspections.
  </p>
  <p>
    Engineered under the patronage of a state-owned infrastructure conglomerate to
    standardize service quality across independent service providers. Consists of a
    high-concurrency consumer booking app and a partner workflow tool for technician dispatch,
    logistics, and payout management.
  </p>
</ProjectSection>
