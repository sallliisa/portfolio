---
import ProjectSection from "../ProjectSection.astro";
---

<ProjectSection
  id="project-public-information-portal"
  title="Public Information Portal"
  images={["/images/ppid-sier.png", "", ""]}
>
  <p>
    Enterprise public information disclosure and document governance portal
    built to comply with national freedom of information and statutory
    transparency mandates.
  </p>
  <p>
    Features a secure request filing intake system, document accessibility
    classification workflows (public, restricted, confidential), officer
    approval chains, response management timelines, and a searchable public
    document archive repository.
  </p>
</ProjectSection>
