---
import ProjectSection from '../ProjectSection.astro';
---

<ProjectSection
  id="project-airwave"
  title="Airwave"
  images={[
    "/images/airwave-spatial.png",
    "/images/airwave-headphones.png",
    "/images/airwave-settings.png"
  ]}
>
  <p>
    A macOS application that provides system-wide spatial audio
    through headphones using HRIR convolution. Built as a free,
    customizable alternative to proprietary spatial audio solutions —
    because tools like these shouldn't cost a subscription.
  </p>
  <p>
    Routes all system audio through a real-time convolution pipeline
    at ~0.1% CPU. Compatible with HeSuVi HRIR presets. Written in
    Swift.
  </p>
</ProjectSection>
