---
interface Props {
  id: string;
  title: string;
  images: string[];
}

const { id, title, images } = Astro.props;
---

<section class="project" id={id}>
  <div class="project-images" aria-hidden="true">
    {images.map((src, index) => (
      <img
        src={src}
        alt=""
        class={`project-img project-img-${index + 1}`}
      />
    ))}
  </div>
  <div class="project-content">
    <h1 class="project-title" id={`project-title-${id}`}>{title}</h1>
    <div class="project-desc">
      <slot />
    </div>
  </div>
</section>
